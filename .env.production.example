# Production Environment Configuration for Backend
# Copy this file to .env and update with your production values

# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# Qdrant Configuration (if using Qdrant Cloud)
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Server Configuration for Production
# Listen on all interfaces (0.0.0.0) in production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000

# CORS - Allow your production frontend domain(s)
# For www.srpski-istoricar.rs deployment:
ALLOWED_ORIGINS=https://www.srpski-istoricar.rs,https://srpski-istoricar.rs

# Frontend URL (for redirects/links)
FRONTEND_URL=https://www.srpski-istoricar.rs
