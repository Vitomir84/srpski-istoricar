# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# OpenAI Base URL (default is OpenAI, but you can use Azure OpenAI or other compatible endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use (gpt-4o-mini is cost-effective, gpt-4o for better quality)
MODEL_NAME=gpt-4o-mini

# Qdrant Configuration
# For local Qdrant: http://localhost:6333
# For Qdrant Cloud: https://your-cluster.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# Optional: Qdrant API Key (only needed for Qdrant Cloud)
# QDRANT_API_KEY=your-qdrant-api-key

# Server Configuration
# Backend server host (0.0.0.0 for all interfaces, 127.0.0.1 for local only)
BACKEND_HOST=127.0.0.1

# Backend server port
BACKEND_PORT=5000

# Allowed origins for CORS (comma-separated)
# For development: http://localhost:3000,http://127.0.0.1:3000
# For production: https://www.srpski-istoricar.rs,https://srpski-istoricar.rs
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend URL (used for redirects and links)
FRONTEND_URL=http://localhost:3000
