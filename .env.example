# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# OpenAI Base URL (default is OpenAI, but you can use Azure OpenAI or other compatible endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use (gpt-4o-mini is cost-effective, gpt-4o for better quality)
MODEL_NAME=gpt-4o-mini

# Qdrant Configuration
# For local Qdrant: http://localhost:6333
# For Qdrant Cloud: https://your-cluster.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# Optional: Qdrant API Key (only needed for Qdrant Cloud)
# QDRANT_API_KEY=your-qdrant-api-key
